{
  "name": "deni-ai",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "bun typecheck && next build",
    "start": "next start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write",
    "typecheck": "tsgo --noEmit",
    "auth:generate": "auth generate --output src/db/schema/auth-schema.ts --yes",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run --env-file=.env.production drizzle-kit migrate",
    "db:migrate:dev": "bun run --env-file=.env.local db:migrate",
    "db:push": "drizzle-kit push",
    "tools:codename": "bun ./tools/codename-generator.ts",
    "tools:commit": "bun ./tools/commit.ts",
    "tools:purge-anonymous": "bun --env-file=.env.production ./tools/purge-anonymous.ts",
    "disposable:refresh": "bun run --filter @deni-ai/disposable-email-domains refresh",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.0",
    "@ai-sdk/google": "^3.0.83",
    "@ai-sdk/groq": "^3.0.42",
    "@ai-sdk/openai": "^3.0.74",
    "@ai-sdk/react": "^3.0.210",
    "@ai-sdk/xai": "^3.0.96",
    "@better-auth/drizzle-adapter": "^1.6.20",
    "@better-auth/passkey": "^1.6.20",
    "@daveyplate/better-auth-tanstack": "^1.3.6",
    "@daveyplate/better-auth-ui": "^3.4.0",
    "@deni-ai/disposable-email-domains": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@icons-pack/react-simple-icons": "13.13.0",
    "@neondatabase/serverless": "^1.1.0",
    "@next/third-parties": "^16.2.9",
    "@openrouter/ai-sdk-provider": "^2.9.1",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@react-email/components": "^1.0.12",
    "@rive-app/react-webgl2": "^4.29.1",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "^5.101.0",
    "@trpc/client": "^11.18.0",
    "@trpc/react-query": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "@upstash/redis": "^1.38.0",
    "@xyflow/react": "^12.11.1",
    "ai": "^6.0.208",
    "ansi-to-react": "^6.2.6",
    "better-auth": "^1.6.20",
    "botid": "1.5.11",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "cnfast": "^0.0.8",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.21.0",
    "media-chrome": "^4.19.2",
    "motion": "^12.40.0",
    "nanoid": "^5.1.15",
    "next": "^16.2.9",
    "next-intl": "^4.13.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.80.0",
    "react-jsx-parser": "^2.4.1",
    "resend": "^6.14.0",
    "shiki": "^4.2.0",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "stripe": "^22.2.3",
    "superjson": "^2.2.6",
    "tokenlens": "^1.3.1",
    "uploadthing": "^7.7.4",
    "use-stick-to-bottom": "^1.1.6",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260623.1",
    "auth": "^1.6.20",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "react-doctor": "^0.5.8",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@swc/core",
    "core-js"
  ]
}
