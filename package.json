{
  "name": "deni-ai",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "bun typecheck && next build",
    "start": "next start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write",
    "typecheck": "tsgo --noEmit",
    "auth:generate": "auth generate --output src/db/schema/auth-schema.ts --yes",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun run --env-file=.env.production drizzle-kit migrate",
    "db:migrate:dev": "bun run --env-file=.env.local db:migrate",
    "db:push": "drizzle-kit push",
    "tools:codename": "bun ./tools/codename-generator.ts",
    "tools:commit": "bun ./tools/commit.ts",
    "tools:purge-anonymous": "bun --env-file=.env.production ./tools/purge-anonymous.ts",
    "disposable:refresh": "bun run --filter @deni-ai/disposable-email-domains refresh",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.12",
    "@ai-sdk/google": "^4.0.12",
    "@ai-sdk/groq": "^4.0.8",
    "@ai-sdk/openai": "^4.0.11",
    "@ai-sdk/react": "^4.0.23",
    "@ai-sdk/xai": "^4.0.10",
    "@base-ui/react": "^1.6.0",
    "@better-auth-ui/core": "^1.6.27",
    "@better-auth-ui/react": "^1.6.27",
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@better-auth/passkey": "^1.6.23",
    "@deni-ai/disposable-email-domains": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@icons-pack/react-simple-icons": "13.13.0",
    "@marsidev/react-turnstile": "^1.5.3",
    "@neondatabase/serverless": "^1.1.0",
    "@next/third-parties": "^16.2.10",
    "@openrouter/ai-sdk-provider": "^3.0.0",
    "@react-email/components": "^1.0.12",
    "@rive-app/react-webgl2": "^4.29.5",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@stripe/react-stripe-js": "^6.7.0",
    "@stripe/stripe-js": "^9.9.0",
    "@t3-oss/env-nextjs": "^0.13.11",
    "@tanstack/react-query": "^5.101.2",
    "@trpc/client": "^11.18.0",
    "@trpc/react-query": "^11.18.0",
    "@trpc/server": "^11.18.0",
    "@upstash/redis": "^1.38.0",
    "@xyflow/react": "^12.11.2",
    "ai": "^7.0.22",
    "ansi-to-react": "^6.2.6",
    "better-auth": "^1.6.23",
    "botid": "1.5.11",
    "bowser": "^2.14.1",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "cmdk": "^1.1.1",
    "cnfast": "^0.0.8",
    "date-fns": "^4.4.0",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.24.0",
    "media-chrome": "^4.19.2",
    "motion": "^12.42.2",
    "nanoid": "^5.1.16",
    "next": "^16.3.0-canary.83",
    "next-intl": "^4.13.2",
    "next-themes": "^0.4.6",
    "react": "19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.81.0",
    "react-jsx-parser": "^2.4.1",
    "resend": "^6.17.2",
    "shiki": "^4.3.1",
    "sonner": "^2.0.7",
    "streamdown": "^2.5.0",
    "stripe": "^22.3.1",
    "superjson": "^2.2.6",
    "tokenlens": "^1.3.1",
    "uploadthing": "^7.7.4",
    "use-stick-to-bottom": "^1.1.6",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@typescript/native-preview": "^7.0.0-dev.20260707.2",
    "auth": "^1.6.23",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "react-doctor": "^0.7.5",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@swc/core",
    "core-js"
  ]
}
